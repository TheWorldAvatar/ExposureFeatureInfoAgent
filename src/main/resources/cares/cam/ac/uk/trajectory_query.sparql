PREFIX time: <http://www.w3.org/2006/time#>
PREFIX timeseries: <https://www.theworldavatar.com/kg/ontotimeseries/>
PREFIX exposure: <https://www.theworldavatar.com/kg/ontoexposure/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT DISTINCT ?val ?result
WHERE {
    <[TRIP_IRI]> timeseries:hasTimeSeries ?timeseries .
    ?result timeseries:hasTimeSeries ?timeseries .
    ?obsTrip timeseries:observationOf <[TRIP_IRI]> ;
              time:hasTime/time:inTimePosition/time:numericPosition "[TIME_VALUE]"^^xsd:double ;
              timeseries:hasResult/timeseries:hasValue "[TRIP_VALUE]"^^xsd:integer .

    ?obsTraj timeseries:observationOf ?result ;
              time:hasTime/time:inTimePosition/time:numericPosition "[TIME_VALUE]"^^xsd:double ;
              timeseries:hasResult/timeseries:hasValue ?val .

    ?result a exposure:ExposureResult .
}
GROUP BY ?result ?val
